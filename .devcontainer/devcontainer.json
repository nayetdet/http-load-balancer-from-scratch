{
  "name": "workspace",

  "image": "mcr.microsoft.com/devcontainers/base:bookworm",

  "mounts": [
    "source=${localEnv:HOME}/.codex,target=/home/vscode/.codex,type=bind",
    "source=${localEnv:HOME}/.kube,target=/home/vscode/.kube,type=bind"
  ],

  "runArgs": [
    "--network=host",
    "--security-opt=label=disable"
  ],

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },

    "ghcr.io/devcontainers-extra/features/bun:1": {},

    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.14"
    },

    "ghcr.io/va-h/devcontainers-features/uv:1": {},

    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},

    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest"
    },

    "ghcr.io/devcontainers-extra/features/kind:1": {}
  },

  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.bun/bin"
  },

  "postCreateCommand": "bun add -g @openai/codex",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
